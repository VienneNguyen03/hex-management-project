@page "/forgot-password"
@using HexManager.Services
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Forgot Password - Hex Manager</PageTitle>

<div class="forgot-password-container">
    <div class="forgot-password-content">
        <img src="/logo_hex.png" alt="Hex Manager" class="forgot-password-logo" />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                @successMessage
            </div>
        }

        @if (!showVerifyDialog && !showResetPasswordForm)
        {
            <div class="forgot-password-form">
                <div class="form-group">
                    <p class="info-text">
                        A verification code will be sent to the authorized email address configured for this system.
                    </p>
                </div>

                <button type="button" class="btn-send-code" @onclick="HandleSendCode" disabled="@sendingCode">
                    @if (sendingCode)
                    {
                        <span class="spinner-small"></span>
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Verification Code</span>
                    }
                </button>
            </div>
        }
        else if (showVerifyDialog && !showResetPasswordForm)
        {
            <EditForm Model="verifyModel" OnValidSubmit="HandleVerifyCode" class="forgot-password-form">
                <div class="form-group">
                    <label class="form-label">Verification Code</label>
                    <InputText @bind-Value="verifyModel.Code" class="form-input" placeholder="Enter 6-digit code" maxlength="6" />
                    <small class="form-help">Check your email for the verification code</small>
                </div>

                <button type="submit" class="btn-verify" disabled="@verifying">
                    @if (verifying)
                    {
                        <span class="spinner-small"></span>
                        <span>Verifying...</span>
                    }
                    else
                    {
                        <span>Verify Code</span>
                    }
                </button>
            </EditForm>
        }
        else if (showResetPasswordForm)
        {
            <EditForm Model="resetPasswordModel" OnValidSubmit="HandleResetPassword" class="forgot-password-form">
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <InputText @bind-Value="resetPasswordModel.NewPassword" type="password" class="form-input" placeholder="Enter new password" />
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <InputText @bind-Value="resetPasswordModel.ConfirmPassword" type="password" class="form-input" placeholder="Confirm new password" />
                    @if (!string.IsNullOrEmpty(passwordMismatchError))
                    {
                        <small class="form-error">@passwordMismatchError</small>
                    }
                </div>

                <button type="submit" class="btn-reset-password" disabled="@resettingPassword">
                    @if (resettingPassword)
                    {
                        <span class="spinner-small"></span>
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </button>
            </EditForm>
        }

        <div class="forgot-password-footer">
            <a href="/login" class="back-to-login-link">Back to Login</a>
        </div>
    </div>
</div>

@code {
    private VerifyModel verifyModel = new();
    private ResetPasswordModel resetPasswordModel = new();
    private bool sendingCode = false;
    private bool verifying = false;
    private bool resettingPassword = false;
    private bool showVerifyDialog = false;
    private bool showResetPasswordForm = false;
    private string? errorMessage;
    private string? successMessage;
    private string? passwordMismatchError;
    private string? authorizedEmail;

    protected override void OnInitialized()
    {
        authorizedEmail = Configuration["Authentication:AuthorizedEmail"];
    }

    private async Task HandleSendCode()
    {
        errorMessage = null;
        successMessage = null;
        sendingCode = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrEmpty(authorizedEmail))
            {
                errorMessage = "Authorized email is not configured. Please contact administrator.";
                return;
            }

            // Use authorized email from config, not user input
            await AuthService.GenerateVerificationCodeAsync(authorizedEmail);
            successMessage = "Verification code has been sent. Please check your email.";
            showVerifyDialog = true;
        }
        catch (UnauthorizedAccessException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to send verification code: {ex.Message}";
        }
        finally
        {
            sendingCode = false;
            StateHasChanged();
        }
    }

    private async Task HandleVerifyCode()
    {
        errorMessage = null;
        verifying = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrEmpty(authorizedEmail))
            {
                errorMessage = "Authorized email not found. Please start over.";
                showVerifyDialog = false;
                return;
            }

            // Use authorized email from config
            var isValid = await AuthService.VerifyCodeAsync(authorizedEmail, verifyModel.Code);
            
            if (isValid)
            {
                successMessage = "Verification successful! Please enter your new password.";
                showVerifyDialog = false;
                showResetPasswordForm = true;
                errorMessage = null;
            }
            else
            {
                errorMessage = "Invalid verification code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Verification failed: {ex.Message}";
        }
        finally
        {
            verifying = false;
            StateHasChanged();
        }
    }

    private async Task HandleResetPassword()
    {
        errorMessage = null;
        successMessage = null;
        passwordMismatchError = null;
        
        // Validate passwords match
        if (resetPasswordModel.NewPassword != resetPasswordModel.ConfirmPassword)
        {
            passwordMismatchError = "Passwords do not match";
            return;
        }

        if (string.IsNullOrWhiteSpace(resetPasswordModel.NewPassword))
        {
            errorMessage = "Password cannot be empty";
            return;
        }

        if (resetPasswordModel.NewPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters";
            return;
        }

        resettingPassword = true;
        StateHasChanged();

        try
        {
            var success = await AuthService.ResetPasswordAsync(resetPasswordModel.NewPassword);
            
            if (success)
            {
                successMessage = "Password reset successfully! Redirecting to login...";
                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                errorMessage = "Failed to reset password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Password reset failed: {ex.Message}";
        }
        finally
        {
            resettingPassword = false;
            StateHasChanged();
        }
    }

    private class VerifyModel
    {
        public string Code { get; set; } = string.Empty;
    }

    private class ResetPasswordModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}

<style>
    .forgot-password-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        padding: 2rem;
    }

    .forgot-password-content {
        width: 100%;
        max-width: 400px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .forgot-password-logo {
        height: 120px;
        width: auto;
        margin-bottom: 2rem;
    }

    .forgot-password-form {
        width: 100%;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #333;
        font-size: 0.9rem;
    }

    .form-input {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 0.9rem;
        transition: border-color 0.2s;
        background: white;
    }

    .form-input:focus {
        outline: none;
        border-color: #714B67;
    }

    .form-help {
        display: block;
        margin-top: 0.25rem;
        color: #666;
        font-size: 0.8rem;
    }

    .info-text {
        color: #555;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }

    .btn-send-code, .btn-verify, .btn-reset-password {
        width: 100%;
        padding: 0.875rem;
        background: #714B67;
        color: white;
        border: none;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .btn-send-code:hover:not(:disabled), .btn-verify:hover:not(:disabled), .btn-reset-password:hover:not(:disabled) {
        background: #5a3a52;
    }

    .btn-send-code:disabled, .btn-verify:disabled, .btn-reset-password:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .form-error {
        display: block;
        margin-top: 0.25rem;
        color: #c33;
        font-size: 0.8rem;
    }

    .forgot-password-footer {
        margin-top: 1.5rem;
        text-align: center;
    }

    .back-to-login-link {
        color: #714B67;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

    .back-to-login-link:hover {
        color: #5a3a52;
        text-decoration: underline;
    }

    .alert {
        padding: 1rem;
        border-radius: 4px;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        width: 100%;
    }

    .alert-danger {
        background: #fee;
        border: 1px solid #fcc;
        color: #c33;
    }

    .alert-success {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .spinner-small {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>
