@code {
    [Parameter]
    public int Id { get; set; }

    private TrafficSignal signal = new();
    private bool saving = false;
    private bool hexExists = false;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (Id > 0)
        {
            var existing = await SignalService.GetByIdAsync(Id);
            if (existing != null)
            {
                signal = existing;
            }
            else
            {
                Navigation.NavigateTo("/");
            }
        }
    }

    private async Task GenerateHex()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            signal.HexAddress = await HexGenerator.GenerateNextHexAddressAsync();
            hexExists = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating HEX: {ex.Message}";
        }
    }

    private string GetHexInputClass()
    {
        return hexExists ? "form-input hex-input input-error" : "form-input hex-input";
    }

    private void OnHexAddressInput(ChangeEventArgs e)
    {
        hexExists = false;
        errorMessage = null;
        successMessage = null;
        if (e.Value != null)
        {
            signal.HexAddress = e.Value.ToString()?.ToUpper() ?? "";
        }
    }

    private async Task HandleSubmit()
    {
        // Reset messages
        errorMessage = null;
        successMessage = null;
        hexExists = false;
        
        // Trim and uppercase HEX address
        if (!string.IsNullOrWhiteSpace(signal.HexAddress))
        {
            signal.HexAddress = signal.HexAddress.ToUpper().Trim();
        }

        // Basic client-side validation
        if (string.IsNullOrWhiteSpace(signal.HexAddress))
        {
            errorMessage = "HEX Address is required";
            return;
        }

        if (!HexGenerator.IsValidHexAddress(signal.HexAddress))
        {
            errorMessage = "Invalid HEX address format. Must be 4 hexadecimal characters (0-9, A-F)";
            hexExists = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(signal.Boro))
        {
            errorMessage = "Borough is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(signal.StreetName1))
        {
            errorMessage = "Street Name 1 is required";
            return;
        }

        if (signal.StreetName1.Length < 2)
        {
            errorMessage = "Street Name 1 must be at least 2 characters";
            return;
        }

        // Validate coordinates
        if (signal.Latitude.HasValue && (signal.Latitude.Value < -90 || signal.Latitude.Value > 90))
        {
            errorMessage = "Latitude must be between -90 and 90";
            return;
        }

        if (signal.Longitude.HasValue && (signal.Longitude.Value < -180 || signal.Longitude.Value > 180))
        {
            errorMessage = "Longitude must be between -180 and 180";
            return;
        }

        saving = true;

        try
        {
            if (Id > 0)
            {
                await SignalService.UpdateAsync(signal);
                successMessage = "Signal updated successfully";
            }
            else
            {
                await SignalService.CreateAsync(signal);
                successMessage = "Signal created successfully";
            }
            
            await Task.Delay(1500);
            Navigation.NavigateTo("/");
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            hexExists = ex.Message.Contains("already exists");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}

