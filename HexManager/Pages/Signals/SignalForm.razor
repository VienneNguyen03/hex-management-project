@page "/signals/create"
@page "/signals/edit/{Id:int}"
@using HexManager.Models
@using HexManager.Services
@inject ITrafficSignalService SignalService
@inject IHexGeneratorService HexGenerator
@inject NavigationManager Navigation

<PageTitle>@(Id > 0 ? "Edit" : "Create") Traffic Signal</PageTitle>

<div class="odoo-form-view">
    <!-- Form Header with Actions -->
    <div class="form-header">
        <h1 class="form-title">@(Id > 0 ? "Edit" : "Create") Traffic Signal</h1>
        <div class="form-actions">
            <button type="button" class="btn-save" @onclick="HandleSubmit" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner"></span>
                }
                Save
            </button>
            <a href="/" class="btn-cancel">Discard</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }


    <EditForm Model="signal" class="odoo-form" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <!-- HEX Address Section -->
        <div class="form-section">
            <h2 class="section-title">HEX Address Information</h2>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label class="form-label required">HEX Address</label>
                    <div class="input-with-button">
                        <InputText @bind-Value="signal.HexAddress" 
                                   class="@GetHexInputClass()" 
                                   placeholder="Enter 4-character HEX (e.g., 7001)" 
                                   maxlength="4"
                                   @oninput="OnHexAddressInput" />
                        @if (Id == 0)
                        {
                            <button type="button" class="btn-generate" @onclick="GenerateHex">
                                Auto Generate
                            </button>
                        }
                    </div>
                    <small class="form-help">Must be 4 hexadecimal characters (0-9, A-F)</small>
                    <ValidationMessage For="@(() => signal.HexAddress)" class="field-error" />
                    @if (hexExists)
                    {
                        <div class="field-error">This HEX address already exists!</div>
                    }
                </div>
            </div>
        </div>

        <!-- Basic Information Section -->
        <div class="form-section">
            <h2 class="section-title">Basic Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Police Code</label>
                    <InputText @bind-Value="signal.PoliceCode" class="form-input" placeholder="Enter police code" />
                </div>
                
                <div class="form-group">
                    <label class="form-label required">Borough</label>
                    <InputSelect @bind-Value="signal.Boro" class="form-select">
                        <option value="">Select Borough</option>
                        <option value="1">Manhattan</option>
                        <option value="2">Bronx</option>
                        <option value="3">Brooklyn</option>
                        <option value="4">Queens</option>
                        <option value="5">Staten Island</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => signal.Boro)" class="field-error" />
                </div>

                <div class="form-group">
                    <label class="form-label">Key BIP</label>
                    <InputText @bind-Value="signal.KeyBIP" class="form-input" placeholder="Enter key BIP" />
                </div>

                <div class="form-group">
                    <label class="form-label">Node ID</label>
                    <InputText @bind-Value="signal.NodeId" class="form-input" placeholder="Enter node ID" />
                </div>

                <div class="form-group">
                    <label class="form-label">Segment ID</label>
                    <InputText @bind-Value="signal.SegmentId" class="form-input" placeholder="Enter segment ID" />
                </div>

                <div class="form-group">
                    <label class="form-label">UID</label>
                    <InputText @bind-Value="signal.UID" class="form-input" placeholder="Enter UID" />
                </div>
            </div>
        </div>

        <!-- Administrative Information Section -->
        <div class="form-section">
            <h2 class="section-title">Administrative Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Sequence Number</label>
                    <InputText @bind-Value="signal.SequenceNumber" class="form-input" placeholder="Enter sequence number" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Area Number</label>
                    <InputText @bind-Value="signal.AreaNumber" class="form-input" placeholder="Enter area number" />
                </div>

                <div class="form-group">
                    <label class="form-label">Machine Number</label>
                    <InputText @bind-Value="signal.MachineNumber" class="form-input" placeholder="Enter machine number" />
                </div>

                <div class="form-group">
                    <label class="form-label">Section</label>
                    <InputText @bind-Value="signal.Section" class="form-input" placeholder="Enter section" />
                </div>

                <div class="form-group">
                    <label class="form-label">Logical Number</label>
                    <InputText @bind-Value="signal.LogicalNumber" class="form-input" placeholder="Enter logical number" />
                </div>

                <div class="form-group">
                    <label class="form-label">GeoKey1</label>
                    <InputText @bind-Value="signal.GeoKey1" class="form-input" placeholder="Enter GeoKey1" />
                </div>

                <div class="form-group">
                    <label class="form-label">GeoKey Street 1</label>
                    <InputText @bind-Value="signal.GeoKeyStreet1" class="form-input" placeholder="Enter GeoKey Street 1" />
                </div>

                <div class="form-group">
                    <label class="form-label">GeoKey Street 2</label>
                    <InputText @bind-Value="signal.GeoKeyStreet2" class="form-input" placeholder="Enter GeoKey Street 2" />
                </div>

                <div class="form-group">
                    <label class="form-label">On Line</label>
                    <InputText @bind-Value="signal.OnLine" class="form-input" placeholder="Enter on line" />
                </div>
            </div>
        </div>

        <!-- Street Information Section -->
        <div class="form-section">
            <h2 class="section-title">Street Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label required">Street Name 1</label>
                    <InputText @bind-Value="signal.StreetName1" class="form-input" placeholder="Enter primary street name" />
                    <ValidationMessage For="@(() => signal.StreetName1)" class="field-error" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Street Code 1</label>
                    <InputText @bind-Value="signal.StreetCode1" class="form-input" placeholder="Enter street code" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Street Name 2</label>
                    <InputText @bind-Value="signal.StreetName2" class="form-input" placeholder="Enter secondary street name" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Street Code 2</label>
                    <InputText @bind-Value="signal.StreetCode2" class="form-input" placeholder="Enter street code" />
                </div>

                <div class="form-group">
                    <label class="form-label">Street Name 3</label>
                    <InputText @bind-Value="signal.StreetName3" class="form-input" placeholder="Enter street name" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Street Code 3</label>
                    <InputText @bind-Value="signal.StreetCode3" class="form-input" placeholder="Enter street code" />
                </div>

                <div class="form-group">
                    <label class="form-label">Street Name 4</label>
                    <InputText @bind-Value="signal.StreetName4" class="form-input" placeholder="Enter street name" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Street Code 4</label>
                    <InputText @bind-Value="signal.StreetCode4" class="form-input" placeholder="Enter street code" />
                </div>
            </div>
        </div>

        <!-- Controller Information Section -->
        <div class="form-section">
            <h2 class="section-title">Controller Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Controller Type</label>
                    <InputText @bind-Value="signal.ControllerType" class="form-input" placeholder="Enter controller type" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Controller Number</label>
                    <InputText @bind-Value="signal.ControllerNumber" class="form-input" placeholder="Enter controller number" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Controller Serial Number</label>
                    <InputText @bind-Value="signal.ControllerSerialNumber" class="form-input" placeholder="Enter serial number" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Equipment Type</label>
                    <InputText @bind-Value="signal.EquipmentType" class="form-input" placeholder="Enter equipment type" />
                </div>

                <div class="form-group">
                    <label class="form-label">Signal Type</label>
                    <InputText @bind-Value="signal.SignalType" class="form-input" placeholder="Enter signal type" />
                </div>

                <div class="form-group">
                    <label class="form-label">Pole Type</label>
                    <InputText @bind-Value="signal.PoleType" class="form-input" placeholder="Enter pole type" />
                </div>

                <div class="form-group">
                    <label class="form-label">Controller Loop Type</label>
                    <InputText @bind-Value="signal.ControllerLoopType" class="form-input" placeholder="Enter loop type" />
                </div>

                <div class="form-group">
                    <label class="form-label">Controller Loop Number</label>
                    <InputText @bind-Value="signal.ControllerLoopNumber" class="form-input" placeholder="Enter loop number" />
                </div>

                <div class="form-group">
                    <label class="form-label">Loop Qty</label>
                    <InputText @bind-Value="signal.LoopQty" class="form-input" placeholder="Enter loop quantity" />
                </div>

                <div class="form-group">
                    <label class="form-label">Controller Dial No</label>
                    <InputText @bind-Value="signal.ControllerDialNo" class="form-input" placeholder="Enter dial number" />
                </div>

                <div class="form-group">
                    <label class="form-label">Auxiliary Cabinets No</label>
                    <InputText @bind-Value="signal.AuxiliaryCabinetsNo" class="form-input" placeholder="Enter auxiliary cabinets number" />
                </div>
            </div>
        </div>

        <!-- MOXA Information Section -->
        <div class="form-section">
            <h2 class="section-title">MOXA Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">MOXA IMEI</label>
                    <InputText @bind-Value="signal.MoxaIMEI" class="form-input" placeholder="Enter MOXA IMEI" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">MOXA CMWN</label>
                    <InputText @bind-Value="signal.MoxaCMWN" class="form-input" placeholder="Enter MOXA CMWN" />
                </div>

                <div class="form-group">
                    <label class="form-label">Computer Flag</label>
                    <InputText @bind-Value="signal.ComputerFlag" class="form-input" placeholder="Enter computer flag" />
                </div>
            </div>
        </div>

        <!-- ATCS Serial Numbers Section -->
        <div class="form-section">
            <h2 class="section-title">ATCS Serial Numbers</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Cabinet Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentCabSerialNum" class="form-input" placeholder="Enter cabinet serial number" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">BIU Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentBiuSerialNum" class="form-input" placeholder="Enter BIU serial number" />
                </div>

                <div class="form-group">
                    <label class="form-label">CM Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentCmSerialNum" class="form-input" placeholder="Enter CM serial number" />
                </div>

                <div class="form-group">
                    <label class="form-label">CPU Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentCpuSerialNum" class="form-input" placeholder="Enter CPU serial number" />
                </div>

                <div class="form-group">
                    <label class="form-label">PDA Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentPdaSerialNum" class="form-input" placeholder="Enter PDA serial number" />
                </div>

                <div class="form-group">
                    <label class="form-label">DCI Serial Number</label>
                    <InputText @bind-Value="signal.AtcsCurrentDciSerialNum" class="form-input" placeholder="Enter DCI serial number" />
                </div>
            </div>
        </div>

        <!-- Geographic Information Section -->
        <div class="form-section">
            <h2 class="section-title">Geographic Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Latitude</label>
                    <InputNumber @bind-Value="signal.Latitude" class="form-input" placeholder="Enter latitude" />
                    <ValidationMessage For="@(() => signal.Latitude)" class="field-error" />
                    <small class="form-help">Must be between -90 and 90</small>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Longitude</label>
                    <InputNumber @bind-Value="signal.Longitude" class="form-input" placeholder="Enter longitude" />
                    <ValidationMessage For="@(() => signal.Longitude)" class="field-error" />
                    <small class="form-help">Must be between -180 and 180</small>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Mapping X Coordinates</label>
                    <InputNumber @bind-Value="signal.MappingX" class="form-input" placeholder="Enter X coordinate" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Mapping Y Coordinates</label>
                    <InputNumber @bind-Value="signal.MappingY" class="form-input" placeholder="Enter Y coordinate" />
                </div>
            </div>
        </div>

        <!-- Maintenance Dates - Painting Section -->
        <div class="form-section">
            <h2 class="section-title">Painting Maintenance</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Painting Due Date</label>
                    <InputDate @bind-Value="signal.PaintingDueDate" class="form-input" />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Painting Scheduled Date</label>
                    <InputDate @bind-Value="signal.PaintingScheduledDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Painting Completed Date</label>
                    <InputDate @bind-Value="signal.PaintingCompletedDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Paint Start Date</label>
                    <InputDate @bind-Value="signal.PaintStartDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Painting Rods</label>
                    <InputText @bind-Value="signal.PaintingRods" class="form-input" placeholder="Enter painting rods" />
                </div>

                <div class="form-group">
                    <label class="form-label">Painting Hardware</label>
                    <InputText @bind-Value="signal.PaintingHardware" class="form-input" placeholder="Enter painting hardware" />
                </div>
            </div>
        </div>

        <!-- Maintenance Dates - Relamping Section -->
        <div class="form-section">
            <h2 class="section-title">Relamping Maintenance</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Relamping Due Date</label>
                    <InputDate @bind-Value="signal.RelampingDueDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Relamping Scheduled Date</label>
                    <InputDate @bind-Value="signal.RelampingScheduledDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Relamping Completed Date</label>
                    <InputDate @bind-Value="signal.RelampingCompletedDate" class="form-input" />
                </div>
            </div>
        </div>

        <!-- Maintenance Dates - Controller Section -->
        <div class="form-section">
            <h2 class="section-title">Controller Maintenance</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Controller Due Date</label>
                    <InputDate @bind-Value="signal.ControllerDueDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Controller Scheduled Date</label>
                    <InputDate @bind-Value="signal.ControllerScheduledDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Controller Completed Date</label>
                    <InputDate @bind-Value="signal.ControllerCompletedDate" class="form-input" />
                </div>
            </div>
        </div>

        <!-- Maintenance Dates - Stray Voltage Section -->
        <div class="form-section">
            <h2 class="section-title">Stray Voltage Check</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Stray Voltage Check Due Date</label>
                    <InputDate @bind-Value="signal.StrayVoltageCheckDueDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Stray Voltage Check Scheduled Date</label>
                    <InputDate @bind-Value="signal.StrayVoltageCheckScheduledDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Stray Voltage Check Completed Date</label>
                    <InputDate @bind-Value="signal.StrayVoltageCheckCompletedDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Stray Voltage Work Order #</label>
                    <InputText @bind-Value="signal.StrayVoltageOpenWorkOrder" class="form-input" placeholder="Enter work order number" />
                </div>

                <div class="form-group full-width">
                    <label class="form-label">Stray Voltage Inspection Comments</label>
                    <InputTextArea @bind-Value="signal.StrayVoltageInspectionComments" class="form-input" placeholder="Enter inspection comments" rows="3" />
                </div>
            </div>
        </div>

        <!-- Installation and Other Dates Section -->
        <div class="form-section">
            <h2 class="section-title">Installation Dates</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Signal Install Date</label>
                    <InputDate @bind-Value="signal.SignalInstallDate" class="form-input" />
                </div>
            </div>
        </div>

        <!-- Employee Tracking Section -->
        <div class="form-section">
            <h2 class="section-title">Employee Tracking</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Controller Cleaning Employee</label>
                    <InputText @bind-Value="signal.ControllerCleaningEmployee" class="form-input" placeholder="Enter employee name" />
                </div>

                <div class="form-group">
                    <label class="form-label">Painting Employee</label>
                    <InputText @bind-Value="signal.PaintingEmployee" class="form-input" placeholder="Enter employee name" />
                </div>

                <div class="form-group">
                    <label class="form-label">Painting Start Employee</label>
                    <InputText @bind-Value="signal.PaintingStartEmployee" class="form-input" placeholder="Enter employee name" />
                </div>

                <div class="form-group">
                    <label class="form-label">Lamping Employee</label>
                    <InputText @bind-Value="signal.LampingEmployee" class="form-input" placeholder="Enter employee name" />
                </div>
            </div>
        </div>

        <!-- Work Order Information Section -->
        <div class="form-section">
            <h2 class="section-title">Work Order & Contract Information</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">TSMP Intersection Control Number</label>
                    <InputText @bind-Value="signal.TsmpIntersectionControlNumber" class="form-input" placeholder="Enter control number" />
                </div>

                <div class="form-group">
                    <label class="form-label">Contractor Reference Number</label>
                    <InputText @bind-Value="signal.ContractorReferenceNumber" class="form-input" placeholder="Enter contractor reference" />
                </div>
            </div>
        </div>

        <!-- Equipment and Poles Section -->
        <div class="form-section">
            <h2 class="section-title">Poles & Equipment</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">M2 Poles</label>
                    <InputText @bind-Value="signal.M2Poles" class="form-input" placeholder="Enter M2 poles count" />
                </div>

                <div class="form-group">
                    <label class="form-label">S1 Poles</label>
                    <InputText @bind-Value="signal.S1Poles" class="form-input" placeholder="Enter S1 poles count" />
                </div>

                <div class="form-group">
                    <label class="form-label">Cylinders</label>
                    <InputText @bind-Value="signal.Cylinders" class="form-input" placeholder="Enter cylinders" />
                </div>

                <div class="form-group">
                    <label class="form-label">Coastal Foundations</label>
                    <InputText @bind-Value="signal.CoastalFoundations" class="form-input" placeholder="Enter coastal foundations" />
                </div>
            </div>
        </div>

        <!-- Lamps Section -->
        <div class="form-section">
            <h2 class="section-title">Lamps Inventory</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">L67 Lamps</label>
                    <InputText @bind-Value="signal.L67Lamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">L150 Lamps</label>
                    <InputText @bind-Value="signal.L150Lamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">L68 Lamps</label>
                    <InputText @bind-Value="signal.L68Lamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">L116 Lamps</label>
                    <InputText @bind-Value="signal.L116Lamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">D5 LED Lamps</label>
                    <InputText @bind-Value="signal.D5LedLamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">D14 LED Lamps</label>
                    <InputText @bind-Value="signal.D14LedLamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">D7 8 IN LED Lamps</label>
                    <InputText @bind-Value="signal.D78InLedLamps" class="form-input" placeholder="Count" />
                </div>

                <div class="form-group">
                    <label class="form-label">D7 12 IN LED Lamps</label>
                    <InputText @bind-Value="signal.D712InLedLamps" class="form-input" placeholder="Count" />
                </div>
            </div>
        </div>

        <!-- Pedestrian Signals Section -->
        <div class="form-section">
            <h2 class="section-title">Pedestrian Signals</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">LED Peds</label>
                    <InputText @bind-Value="signal.LedPeds" class="form-input" placeholder="Enter LED peds count" />
                </div>

                <div class="form-group">
                    <label class="form-label">Countdown Peds</label>
                    <InputText @bind-Value="signal.CountdownPeds" class="form-input" placeholder="Enter countdown peds count" />
                </div>
            </div>
        </div>

        <!-- Red Light Camera Section -->
        <div class="form-section">
            <h2 class="section-title">Red Light Camera</h2>
            <div class="form-grid three-columns">
                <div class="form-group">
                    <label class="form-label">Camera Type</label>
                    <InputText @bind-Value="signal.RedlightCameraType" class="form-input" placeholder="Enter camera type" />
                </div>

                <div class="form-group">
                    <label class="form-label">Camera Install Date</label>
                    <InputDate @bind-Value="signal.RedlightCameraInstallDate" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Camera Remove Date</label>
                    <InputDate @bind-Value="signal.RedlightCameraRemoveDate" class="form-input" />
                </div>
            </div>
        </div>

        <!-- Battery Backup System Section -->
        <div class="form-section">
            <h2 class="section-title">Battery Backup System (BBS)</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label class="form-label">Battery Backup Model</label>
                    <InputText @bind-Value="signal.BatteryBackupModel" class="form-input" placeholder="Enter battery model" />
                </div>

                <div class="form-group">
                    <label class="form-label">Battery Last Changed</label>
                    <InputDate @bind-Value="signal.BatteryLastChanged" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">BBS Make</label>
                    <InputText @bind-Value="signal.BbsMake" class="form-input" placeholder="Enter BBS make" />
                </div>

                <div class="form-group">
                    <label class="form-label">BBS Model</label>
