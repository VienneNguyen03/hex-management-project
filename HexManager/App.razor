<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@GetLayout(routeData)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private Type? GetLayout(RouteData routeData)
    {
        var path = routeData.PageType?.FullName ?? "";
        var isAuthPage = path.Contains("Login") || path.Contains("ForgotPassword");
        return isAuthPage ? null : typeof(MainLayout);
    }
}
