@using HexManager.Services
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation

@code {
    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(50); // Small delay to ensure cookies are available
        
        var currentPath = Navigation.Uri;
        var relativePath = new Uri(currentPath).AbsolutePath;

        // Allow access to login and forgot-password pages without authentication
        if (relativePath == "/login" || relativePath == "/forgot-password")
        {
            // If already authenticated and trying to access login, redirect to home
            if (relativePath == "/login" && AuthService.IsAuthenticated())
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            return;
        }

        // Redirect to login if not authenticated
        if (!AuthService.IsAuthenticated())
        {
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
