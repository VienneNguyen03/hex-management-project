@if (showNearbyModal)
{
    <div class="custom-modal-backdrop" @onclick="CloseNearbyModal"></div>
    <div class="custom-modal">
        <div class="custom-modal-content">
            <div class="custom-modal-header">
                <h3 style="color: #714B67; font-weight: 600;">Nearby Locations</h3>
                <button type="button" class="btn-close-modal" @onclick="CloseNearbyModal">×</button>
            </div>
            <div class="custom-modal-body">
                <div class="odoo-filters" style="margin-bottom: 1rem; padding: 1rem; background: #f8f9fa; border-radius: 4px; border: 1px solid #e0e0e0;">
                    <div class="filter-group" style="display: flex; gap: 1rem; align-items: flex-end;">
                        <div class="filter-item" style="flex: 1;">
                            <label style="display: block; font-size: 0.8rem; font-weight: 500; color: #555; margin-bottom: 0.3rem;">Search</label>
                            <input type="text"
                                   class="form-input"
                                   placeholder="HEX, Area Number, Street..."
                                   value="@nearbySearchTerm"
                                   @oninput="@(e => { nearbySearchTerm = e.Value?.ToString() ?? ""; nearbyCurrentPage = 1; })" />
                        </div>
                        <div class="filter-item" style="width: 150px;">
                            <label style="display: block; font-size: 0.8rem; font-weight: 500; color: #555; margin-bottom: 0.3rem;">Radius (km)</label>
                            <select class="form-select" value="@nearbyRadiusKm" @onchange="OnRadiusChanged">
                                <option value="5">5 km</option>
                                <option value="10">10 km</option>
                                <option value="20">20 km</option>
                                <option value="50">50 km</option>
                            </select>
                        </div>
                        <div class="filter-item" style="width: 120px;">
                            <label style="display: block; font-size: 0.8rem; font-weight: 500; color: #555; margin-bottom: 0.3rem;">Rows per page</label>
                            <select class="form-select" @bind="nearbyPageSize" @bind:after="@(() => nearbyCurrentPage = 1)">
                                <option value="10">10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                    </div>
                </div>

                @if (filteredNearbySignals.Any())
                {
                    <table class="nearby-table">
                        <thead>
                            <tr>
                                <th style="cursor:pointer; user-select:none;" @onclick="@(() => NearbySort("HEX"))">
                                    HEX @(nearbySortColumn == "HEX" ? (nearbySortAsc ? "▲" : "▼") : "")
                                </th>
                                <th style="cursor:pointer; user-select:none;" @onclick="@(() => NearbySort("Area"))">
                                    Area Number @(nearbySortColumn == "Area" ? (nearbySortAsc ? "▲" : "▼") : "")
                                </th>
                                <th style="cursor:pointer; user-select:none;" @onclick="@(() => NearbySort("Street"))">
                                    Street 1 & 2 @(nearbySortColumn == "Street" ? (nearbySortAsc ? "▲" : "▼") : "")
                                </th>
                                <th style="cursor:pointer; user-select:none;" @onclick="@(() => NearbySort("Distance"))">
                                    Distance (km) @(nearbySortColumn == "Distance" ? (nearbySortAsc ? "▲" : "▼") : "")
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ns in pagedNearbySignals)
                            {
                                <tr style="cursor: pointer;" @onclick="() => AutoFillFromNearby(ns)" title="Click to auto-fill Area Number">
                                    <td><a href="javascript:void(0)" class="action-link" style="color: #714B67; font-weight: 500; text-decoration: none;">@ns.Signal.HexAddress</a></td>
                                    <td>@ns.Signal.AreaNumber</td>
                                    <td>@ns.Signal.StreetName1 / @ns.Signal.StreetName2</td>
                                    <td>@ns.DistanceKm</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div style="display: flex; justify-content: flex-end; align-items: center; gap: 0.75rem; margin-top: 1rem; font-size: 0.85rem; color: #555;">
                        <span>Page @nearbyCurrentPage of @nearbyTotalPages (@filteredNearbySignals.Count total)</span>
                        <button class="btn-page" disabled="@(nearbyCurrentPage <= 1)" @onclick="@(() => nearbyCurrentPage--)">‹</button>
                        <button class="btn-page" disabled="@(nearbyCurrentPage >= nearbyTotalPages)" @onclick="@(() => nearbyCurrentPage++)">›</button>
                    </div>
                }
                else
                {
                    <p>No locations found within @nearbyRadiusKm km matching your criteria.</p>
                }
            </div>
        </div>
    </div>
}

@if (isSearchingNearby)
{
    <div class="fullscreen-loading-overlay">
        <div class="fullscreen-spinner-container">
            <div class="fullscreen-spinner"></div>
            <p class="loading-text">Finding nearby locations...</p>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TrafficSignal signal = new();
    private bool saving = false;
    private bool hexExists = false;
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (Id > 0)
        {
            var existing = await SignalService.GetByIdAsync(Id);
            if (existing != null)
            {
                signal = existing;
            }
            else
            {
                Navigation.NavigateTo("/");
            }
        }
    }

    private bool showNearbyModal = false;
    private bool isSearchingNearby = false;
    private List<NearbySignal> nearbySignals = new();
    private string nearbySearchTerm = "";
    private double nearbyRadiusKm = 20.0;

    // Pagination
    private int nearbyPageSize = 25;
    private int nearbyCurrentPage = 1;

    // Sort
    private string nearbySortColumn = "Distance";
    private bool nearbySortAsc = true;

    // Cached resolved coordinates for radius reload
    private double? nearbyResolvedLat;
    private double? nearbyResolvedLon;

    private List<NearbySignal> filteredNearbySignals
    {
        get
        {
            var list = nearbySignals.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(nearbySearchTerm))
                list = list.Where(x =>
                    (x.Signal.HexAddress?.Contains(nearbySearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Signal.AreaNumber?.Contains(nearbySearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Signal.StreetName1?.Contains(nearbySearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Signal.StreetName2?.Contains(nearbySearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
            list = nearbySortColumn switch
            {
                "HEX"      => nearbySortAsc ? list.OrderBy(x => x.Signal.HexAddress)  : list.OrderByDescending(x => x.Signal.HexAddress),
                "Area"     => nearbySortAsc ? list.OrderBy(x => x.Signal.AreaNumber)  : list.OrderByDescending(x => x.Signal.AreaNumber),
                "Street"   => nearbySortAsc ? list.OrderBy(x => x.Signal.StreetName1) : list.OrderByDescending(x => x.Signal.StreetName1),
                _          => nearbySortAsc ? list.OrderBy(x => x.DistanceKm)         : list.OrderByDescending(x => x.DistanceKm),
            };
            return list.ToList();
        }
    }

    private List<NearbySignal> pagedNearbySignals =>
        filteredNearbySignals.Skip((nearbyCurrentPage - 1) * nearbyPageSize).Take(nearbyPageSize).ToList();

    private int nearbyTotalPages =>
        (int)Math.Ceiling(filteredNearbySignals.Count / (double)nearbyPageSize);

    private void NearbySort(string column)
    {
        if (nearbySortColumn == column)
            nearbySortAsc = !nearbySortAsc;
        else
        {
            nearbySortColumn = column;
            nearbySortAsc = true;
        }
        nearbyCurrentPage = 1;
    }

    private async Task FindNearbySignals()
    {
        isSearchingNearby = true;
        StateHasChanged();
        await Task.Delay(50);

        try
        {
            double? latToUse = null;
            double? lonToUse = null;

            if (signal.Latitude.HasValue && signal.Longitude.HasValue)
            {
                latToUse = (double)signal.Latitude.Value;
                lonToUse = (double)signal.Longitude.Value;
            }
            else if (!string.IsNullOrWhiteSpace(signal.StreetName1) && !string.IsNullOrWhiteSpace(signal.StreetName2))
            {
                var coords = await SignalService.GetCoordinatesByStreetNamesAsync(signal.StreetName1, signal.StreetName2);
                if (coords != null)
                {
                    latToUse = coords.Value.Latitude;
                    lonToUse = coords.Value.Longitude;
                }
                else
                {
                    errorMessage = "Cannot find coordinates for Street 1 & 2 in database.";
                }
            }
            else
            {
                errorMessage = "Please enter Latitude/Longitude or Street Name 1 & 2.";
            }

            if (latToUse.HasValue && lonToUse.HasValue)
            {
                nearbyResolvedLat = latToUse;
                nearbyResolvedLon = lonToUse;
                nearbyCurrentPage = 1;
                nearbySignals = await SignalService.FindNearbySignalsAsync(latToUse.Value, lonToUse.Value, nearbyRadiusKm);
                if (Id > 0)
                    nearbySignals = nearbySignals.Where(x => x.Signal.Id != Id).ToList();
                showNearbyModal = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error searching nearby: {ex.Message}";
        }
        finally
        {
            isSearchingNearby = false;
        }
    }

    private async Task OnRadiusChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var km))
            nearbyRadiusKm = km;
        await ReloadNearbyWithRadius();
    }

    private async Task ReloadNearbyWithRadius()
    {
        if (!nearbyResolvedLat.HasValue || !nearbyResolvedLon.HasValue) return;
        isSearchingNearby = true;
        StateHasChanged();
        await Task.Delay(50);
        try
        {
            nearbyCurrentPage = 1;
            nearbySignals = await SignalService.FindNearbySignalsAsync(nearbyResolvedLat.Value, nearbyResolvedLon.Value, nearbyRadiusKm);
            if (Id > 0)
                nearbySignals = nearbySignals.Where(x => x.Signal.Id != Id).ToList();
        }
        finally
        {
            isSearchingNearby = false;
        }
    }

    private void CloseNearbyModal()
    {
        showNearbyModal = false;
    }

    private void AutoFillFromNearby(NearbySignal ns)
    {
        var filledFields = new List<string>();

        signal.AreaNumber = ns.Signal.AreaNumber;
        filledFields.Add($"Area Number '{ns.Signal.AreaNumber}'");

        if (!string.IsNullOrEmpty(ns.Signal.Boro) && string.IsNullOrEmpty(signal.Boro))
        {
            signal.Boro = ns.Signal.Boro;
            filledFields.Add("Boro");
        }

        if (string.IsNullOrEmpty(signal.StreetName1) && !string.IsNullOrEmpty(ns.Signal.StreetName1))
        {
            signal.StreetName1 = ns.Signal.StreetName1;
            filledFields.Add("Street 1");
        }

        if (string.IsNullOrEmpty(signal.StreetName2) && !string.IsNullOrEmpty(ns.Signal.StreetName2))
        {
            signal.StreetName2 = ns.Signal.StreetName2;
            filledFields.Add("Street 2");
        }
        
        string joinedFields = string.Join(", ", filledFields);
        successMessage = $"Auto-filled {joinedFields} from nearby location {ns.Signal.HexAddress}.";
        errorMessage = null;
        showNearbyModal = false;
    }

    private async Task GenerateHex()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            signal.HexAddress = await HexGenerator.GenerateNextHexAddressAsync();
            hexExists = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generating HEX: {ex.Message}";
        }
    }

    private string GetHexInputClass()
    {
        return hexExists ? "form-input hex-input input-error" : "form-input hex-input";
    }

    private void OnHexAddressInput(ChangeEventArgs e)
    {
        hexExists = false;
        if (e.Value != null)
            signal.HexAddress = e.Value.ToString()?.ToUpper() ?? "";
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        successMessage = null;
        hexExists = false;

        if (!string.IsNullOrWhiteSpace(signal.HexAddress))
            signal.HexAddress = signal.HexAddress.ToUpper().Trim();

        if (string.IsNullOrWhiteSpace(signal.HexAddress))
        {
            errorMessage = "HEX Address is required";
            return;
        }

        if (!HexGenerator.IsValidHexAddress(signal.HexAddress))
        {
            errorMessage = "Invalid HEX address format. Must be 4 hexadecimal characters (0-9, A-F)";
            hexExists = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(signal.Boro))
        {
            errorMessage = "Borough is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(signal.StreetName1))
        {
            errorMessage = "Street Name 1 is required";
            return;
        }

        if (signal.StreetName1.Length < 2)
        {
            errorMessage = "Street Name 1 must be at least 2 characters";
            return;
        }

        if (signal.Latitude.HasValue && (signal.Latitude.Value < -90 || signal.Latitude.Value > 90))
        {
            errorMessage = "Latitude must be between -90 and 90";
            return;
        }

        if (signal.Longitude.HasValue && (signal.Longitude.Value < -180 || signal.Longitude.Value > 180))
        {
            errorMessage = "Longitude must be between -180 and 180";
            return;
        }

        saving = true;

        try
        {
            if (Id > 0)
            {
                await SignalService.UpdateAsync(signal);
                successMessage = "Signal updated successfully";
            }
            else
            {
                await SignalService.CreateAsync(signal);
                successMessage = "Signal created successfully";
            }

            await Task.Delay(1500);
            Navigation.NavigateTo("/");
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
            hexExists = ex.Message.Contains("already exists");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}

